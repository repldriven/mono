{:compact-views #{}
 :default-profile-name "example"
 :interface-ns "interface"
 :projects {"development" {:alias "dev"}
            "example-service" {:alias "example" :necessary ["test-resources"]}
            ;; Library projects have no base, so every component that nothing
            ;; else depends on looks unnecessary to warning 207. Listing them as
            ;; :necessary is how a base-less project is declared intentional.
            "mono-lib" {:alias "lib"
                        :necessary ["cache" "cli" "command-processor"
                                    "command-schema" "event-processor"
                                    "event-schema" "fdb" "keycloak" "migrator"
                                    "mqtt" "pulsar-vault-crypto" "scheduler"
                                    "secret" "server" "spec" "sql"
                                    "test-resources"]}
            "mono-test-lib" {:alias "test-lib"
                             :necessary ["test-schema" "testcontainers"]}}
 :tag-patterns {:release "v[0-9]*" :stable "stable-*"}
 :test {:create-test-runner
        com.repldriven.mono.external-test-runner.core/create}
 :top-namespace "com.repldriven.mono"
 :vcs {:auto-add true :name "git"}}
