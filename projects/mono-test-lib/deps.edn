;; Publishable test-support root. Consumed under a :test alias only, so that
;; testcontainers and its Docker requirement never reach a consumer's runtime
;; classpath:
;;
;;   {:deps {com.repldriven/mono {:git/url "https://github.com/repldriven/mono.git"
;;                                :git/tag "vX.Y.Z" :git/sha "<full-sha>"
;;                                :deps/root "projects/mono-lib"}}
;;    :aliases {:test {:extra-deps
;;              {com.repldriven/mono {:git/url "https://github.com/repldriven/mono.git"
;;                                    :git/tag "vX.Y.Z" :git/sha "<full-sha>"
;;                                    :deps/root "projects/mono-test-lib"}}}}}
;;
;; ONE lib symbol, two :deps/root values. It must not be two symbols: tools.deps
;; checks out a git dep per lib symbol, so two symbols means two checkouts, and
;; a component this root shares with mono-lib would appear twice at two absolute
;; paths under the same lib symbol. tools.deps cannot reconcile those:
;;
;;   Error building classpath. No known ancestor relationship between local
;;   versions for com.repldriven.mono.components/env
;;
;; and it fails only when both are on one classpath — the documented usage.
;;
;; Because :extra-deps merges over :deps BY LIB SYMBOL, activating :test does
;; not add this root to mono-lib, it REPLACES mono-lib with it. That is safe
;; only while this root is a superset of mono-lib, so it repeats every runtime
;; component and adds the test bricks. The release workflow asserts the superset
;; property; do not hand-prune this list.
;;
;; test-schema is intentionally absent: it carries :deps/prep-lib, and keeping a
;; prep step out of the published surface is worth protecting. It stays an alias
;; dep, used only inside this workspace.
;;
;; test-resources is absent for a different reason: its :paths is ["src"], which
;; holds nothing but an empty namespace. The shared config it exists to carry
;; (testcontainers/*.yml, the pulsar keypairs) lives on :extra-paths under the
;; brick's own :test alias, and a git-dep consumer never activates a dep's
;; aliases — so publishing it would ship an empty ns. The config is workspace
;; -internal anyway: it wires our bricks, and only our brick tests !include it.
{:paths []
 :deps
 {com.repldriven.mono.components/avro
  {:local/root "../../components/avro"}
  com.repldriven.mono.components/cache
  {:local/root "../../components/cache"}
  com.repldriven.mono.components/cli
  {:local/root "../../components/cli"}
  com.repldriven.mono.components/command
  {:local/root "../../components/command"}
  com.repldriven.mono.components/command-processor
  {:local/root "../../components/command-processor"}
  com.repldriven.mono.components/command-schema
  {:local/root "../../components/command-schema"}
  com.repldriven.mono.components/encryption
  {:local/root "../../components/encryption"}
  com.repldriven.mono.components/env
  {:local/root "../../components/env"}
  com.repldriven.mono.components/error
  {:local/root "../../components/error"}
  com.repldriven.mono.components/event
  {:local/root "../../components/event"}
  com.repldriven.mono.components/event-processor
  {:local/root "../../components/event-processor"}
  com.repldriven.mono.components/event-schema
  {:local/root "../../components/event-schema"}
  com.repldriven.mono.components/fdb
  {:local/root "../../components/fdb"}
  com.repldriven.mono.components/http-client
  {:local/root "../../components/http-client"}
  com.repldriven.mono.components/identity-provider
  {:local/root "../../components/identity-provider"}
  com.repldriven.mono.components/jdbc
  {:local/root "../../components/jdbc"}
  com.repldriven.mono.components/kafka
  {:local/root "../../components/kafka"}
  com.repldriven.mono.components/json
  {:local/root "../../components/json"}
  com.repldriven.mono.components/keycloak
  {:local/root "../../components/keycloak"}
  com.repldriven.mono.components/log
  {:local/root "../../components/log"}
  com.repldriven.mono.components/message-bus
  {:local/root "../../components/message-bus"}
  com.repldriven.mono.components/migrator
  {:local/root "../../components/migrator"}
  com.repldriven.mono.components/mqtt
  {:local/root "../../components/mqtt"}
