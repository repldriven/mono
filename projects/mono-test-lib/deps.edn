  com.repldriven.mono.components/system
  {:local/root "../../components/system"}
  com.repldriven.mono.components/telemetry
  {:local/root "../../components/telemetry"}
  com.repldriven.mono.components/test-system
  {:local/root "../../components/test-system"}
  com.repldriven.mono.components/testcontainers
  {:local/root "../../components/testcontainers"}
  com.repldriven.mono.components/utility
