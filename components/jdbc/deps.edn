{:paths ["src"]
 :deps {com.github.seancorfield/next.jdbc {:mvn/version "1.3.1093"}}
 ;; The driver is the consumer's choice; this brick is driver-agnostic. Tests
 ;; need one, so postgres is an alias dep rather than a dep.
 :aliases {:test {:extra-paths ["test" "test-resources"]
                  :extra-deps {org.postgresql/postgresql {:mvn/version
                                                          "42.7.10"}}}}}
